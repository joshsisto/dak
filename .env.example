# Server
HOST=0.0.0.0
PORT=8080

# Multiple calendars (preferred):
# Format: Name|ICS_URL;Other Name|ICS_URL
# Example:
# CALENDAR_SOURCES=Family|https://pXX-caldav.icloud.com/published/2/AAA.ics;Work|https://pXX-caldav.icloud.com/published/2/BBB.ics
CALENDAR_SOURCES=

# iCloud shared calendar (single calendar, backward-compatible option)
# If both CALENDAR_SOURCES and CALENDAR_ICS_URL are set, this one is added too.
CALENDAR_ICS_URL=

CALENDAR_DAYS_AHEAD=7
CALENDAR_EVENT_LIMIT=12

# Cache calendar ICS responses to avoid frequent iCloud requests (12 hours default)
CALENDAR_CACHE_SECONDS=43200
CALENDAR_CACHE_DIRECTORY=./data/cache/calendar

# Export readable calendar events text file
CALENDAR_EVENTS_TEXT_FILE=./data/calendar_events.txt

# Display timezone (example: America/Los_Angeles)
DISPLAY_TIMEZONE=America/Los_Angeles

# Weather (Open-Meteo)
WEATHER_LATITUDE=40.7128
WEATHER_LONGITUDE=-74.0060
WEATHER_TEMPERATURE_UNIT=fahrenheit
WEATHER_WIND_SPEED_UNIT=mph
WEATHER_TIMEZONE=auto
MOON_CACHE_DIRECTORY=./data/cache/moon

# Photos source: "icloud_shared_album" or "directory"
PHOTOS_SOURCE=icloud_shared_album
PHOTOS_DIRECTORY=./photos
PHOTOS_LIMIT=50

# iCloud shared album public URL (example: https://www.icloud.com/sharedalbum/#B0hxyz...)
ICLOUD_SHARED_ALBUM_URL=

# Refresh behavior
DATA_REFRESH_SECONDS=300
SLIDESHOW_INTERVAL_SECONDS=20
HTTP_TIMEOUT_SECONDS=12
